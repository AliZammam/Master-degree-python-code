le=\"Generate code using this dataframe.\"\n","            style=\"display:none;\">\n","\n","  <svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\"viewBox=\"0 0 24 24\"\n","       width=\"24px\">\n","    <path d=\"M7,19H8.4L18.45,9,17,7.55,7,17.6ZM5,21V16.75L18.45,3.32a2,2,0,0,1,2.83,0l1.4,1.43a1.91,1.91,0,0,1,.58,1.4,1.91,1.91,0,0,1-.58,1.4L9.25,21ZM18.45,9,17,7.55Zm-12,3A5.31,5.31,0,0,0,4.9,8.1,5.31,5.31,0,0,0,1,6.5,5.31,5.31,0,0,0,4.9,4.9,5.31,5.31,0,0,0,6.5,1,5.31,5.31,0,0,0,8.1,4.9,5.31,5.31,0,0,0,12,6.5,5.46,5.46,0,0,0,6.5,12Z\"/>\n","  </svg>\n","    </button>\n","    <script>\n","      (() => {\n","      const buttonEl =\n","        document.querySelector('#id_206971f0-6687-4d5a-8748-d34a1f973cb2 button.colab-df-generate');\n","      buttonEl.style.display =\n","        google.colab.kernel.accessAllowed ? 'block' : 'none';\n","\n","      buttonEl.onclick = () => {\n","        google.colab.notebook.generateWithVariable('raw');\n","      }\n","      })();\n","    </script>\n","  </div>\n","\n","    </div>\n","  </div>\n"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"dataframe","variable_name":"raw"}},"metadata":{},"execution_count":10}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"gGVHRlYR5Sxb"},"outputs":[],"source":["# Calendar features\n","raw['day_of_week'] = raw['Date'].dt.dayofweek\n","raw['day_of_month'] = raw['Date'].dt.day\n","raw['month'] = raw['Date'].dt.month\n","\n","# Columns to use\n","categorical_cols = [\n","    'Category',\n","    'Size',\n","    'Style',\n","    'Fulfilment',\n","    'Sales Channel ',\n","    'ship-service-level',\n","    'ship-state',\n","    'B2B',\n","    'fulfilled-by'\n","]\n","\n","numeric_cols = [\n","    'Qty',\n","    'day_of_week',\n","    'day_of_month',\n","    'month'\n","]\n","\n","# Keep only needed columns\n","cols_needed = ['Date', 'Amount'] + categorical_cols + numeric_cols\n","model_df = raw[cols_needed].copy()\n","\n","# Fill missing categoricals\n","for c in categorical_cols:\n","    model_df[c] = model_df[c].fillna('Unknown')"],"id":"gGVHRlYR5Sxb"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"CcBNcvwc5Sxd","executionInfo":{"status":"ok","timestamp":1773412884382,"user_tz":-60,"elapsed":93,"user":{"displayName":"Bayan Dali","userId":"00422725621589951195"}},"outputId":"d6823999-8ad9-4818-c879-d13784dc2a0e"},"outputs":[{"output_type":"stream","name":"stdout","text":["Train size: 84082 Test size: 21021\n"]}],"source":["# Sort by date\n","model_df = model_df.sort_values('Date').reset_index(drop=True)\n","\n","# Use last 20% of rows as test\n","split_idx = int(len(model_df) * 0.8)\n","train_df = model_df.iloc[:split_idx].copy()\n","test_df = model_df.iloc[split_idx:].copy()\n","\n","X_train = train_df[categorical_cols + numeric_cols]\n","y_train = train_df['Amount']\n","X_test = test_df[categorical_cols + numeric_cols]\n","y_test = test_df['Amount']\n","\n","print('Train size:', len(train_df), 'Test size:', len(test_df))"],"id":"CcBNcvwc5Sxd"},{"cell_type":"code","source":["X_train"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":424},"id":"SJeKXwfYIuxD","executionInfo":{"status":"ok","timestamp":1773421131006,"user_tz":-60,"elapsed":712,"user":{"displayName":"Bayan Dali","userId":"00422725621589951195"}},"outputId":"6f514db4-e356-4fdc-b4c8-48c3c1833b0a"},"id":"SJeKXwfYIuxD","execution_count":11,"outputs":[{"output_type":"execute_result","data":{"text/plain":["            Category Size    Style Fulfilment Sales Channel   \\\n","0                Set   XS    J0127     Amazon      Amazon.in   \n","1                Set   XL   SET187     Amazon      Amazon.in   \n","2              kurta    L  JNE3405     Amazon      Amazon.in   \n","3                Set    L   SET044     Amazon      Amazon.in   \n","4                Set    M    J0345     Amazon      Amazon.in   \n","...              ...  ...      ...        ...            ...   \n","84077  Western Dress 