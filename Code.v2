tons\">\n","\n","  <div class=\"colab-df-container\">\n","    <button class=\"colab-df-convert\" onclick=\"convertToInteractive('df-2daffe8a-1e89-4106-8482-c1689120eb76')\"\n","            title=\"Convert this dataframe to an interactive table.\"\n","            style=\"display:none;\">\n","\n","  <svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\">\n","    <path d=\"M120-120v-720h720v720H120Zm60-500h600v-160H180v160Zm220 220h160v-160H400v160Zm0 220h160v-160H400v160ZM180-400h160v-160H180v160Zm440 0h160v-160H620v160ZM180-180h160v-160H180v160Zm440 0h160v-160H620v160Z\"/>\n","  </svg>\n","    </button>\n","\n","  <style>\n","    .colab-df-container {\n","      display:flex;\n","      gap: 12px;\n","    }\n","\n","    .colab-df-convert {\n","      background-color: #E8F0FE;\n","      border: none;\n","      border-radius: 50%;\n","      cursor: pointer;\n","      display: none;\n","      fill: #1967D2;\n","      height: 32px;\n","      padding: 0 0 0 0;\n","      width: 32px;\n","    }\n","\n","    .colab-df-convert:hover {\n","      background-color: #E2EBFA;\n","      box-shadow: 0px 1px 2px rgba(60, 64, 67, 0.3), 0px 1px 3px 1px rgba(60, 64, 67, 0.15);\n","      fill: #174EA6;\n","    }\n","\n","    .colab-df-buttons div {\n","      margin-bottom: 4px;\n","    }\n","\n","    [theme=dark] .colab-df-convert {\n","      background-color: #3B4455;\n","      fill: #D2E3FC;\n","    }\n","\n","    [theme=dark] .colab-df-convert:hover {\n","      background-color: #434B5C;\n","      box-shadow: 0px 1px 3px 1px rgba(0, 0, 0, 0.15);\n","      filter: drop-shadow(0px 1px 2px rgba(0, 0, 0, 0.3));\n","      fill: #FFFFFF;\n","    }\n","  </style>\n","\n","    <script>\n","      const buttonEl =\n","        document.querySelector('#df-2daffe8a-1e89-4106-8482-c1689120eb76 button.colab-df-convert');\n","      buttonEl.style.display =\n","        google.colab.kernel.accessAllowed ? 'block' : 'none';\n","\n","      async function convertToInteractive(key) {\n","        const element = document.querySelector('#df-2daffe8a-1e89-4106-8482-c1689120eb76');\n","        const dataTable =\n","          await google.colab.kernel.invokeFunction('convertToInteractive',\n","                                                    [key], {});\n","        if (!dataTable) return;\n","\n","        const docLinkHtml = 'Like what you see? Visit the ' +\n","          '<a target=\"_blank\" href=https://colab.research.google.com/notebooks/data_table.ipynb>data table notebook</a>'\n","          + ' to learn more about interactive tables.';\n","        element.innerHTML = '';\n","        dataTable['output_type'] = 'display_data';\n","        await google.colab.output.renderOutput(dataTable, element);\n","        const docLink = document.createElement('div');\n","        docLink.innerHTML = docLinkHtml;\n","        element.appendChild(docLink);\n","      }\n","    </script>\n","  </div>\n","\n","\n","    </div>\n","  </div>\n"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"dataframe","summary":"{\n  \"name\": \"pd\",\n  \"rows\": 3,\n  \"fields\": [\n    {\n      \"column\": \"model\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 3,\n        \"samples\": [\n          \"Global median\",\n          \"Category median\",\n          \"Category+Size median\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"MAE\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 35.767168972199215,\n        \"min\": 151.53903239617526,\n        \"max\": 216.15303743875174,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          216.15303743875174,\n          157.26326054897484,\n          151.53903239617526\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"RMSE\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 18137.457217851064,\n        \"min\": 44442.63764806622,\n        \"max\": 77192.76461633605,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          77192.76461633605,\n          47309.40920983778,\n          44442.63764806622\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"R2\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.23923214083674724,\n        \"min\": -0.018168650349608573,\n        \"max\": 0.41380386339301856,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          -0.018168650349608573,\n          0.3759912918856123,\n          0.41380386339301856\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":5}],"source":["# Baseline 1: global median\n","baseline_global = y_test.median()\n","\n","# Baseline 2: median by Category (fallback to global)\n","cat_median = train_df.groupby('Category')['Amount'].median()\n","\n","def predict_cat_median(df):\n","    return df['Category'].map(cat_median).fillna(baseline_global).values\n","\n","pred_cat = predict_cat_median(test_df)\n","\n","# Baseline 3: median by (Category, Size) with fallback\n","cat_size_median = train_df.groupby(['Category', 'Size'])['Amount'].median()\n","\n","def predict_cat_size_median(df):\n","    vals = df.set_index(['Category', 'Size']).index.map(cat_size_median)\n","    return pd.Series(vals).fillna(df['Category'].map(cat_median)).fillna(baseline_global).values\n","\n","pred_cat_size = predict_cat_size_median(test_df)\n","\n","# Evaluate baselines\n","from sklearn.metrics import mean_absolute_error, mean_squared_error\n","\n","def eval_metrics(y_true, y_pred, label):\n","    mae = mean_absolute_error(y_true, y_pred)\n","    rmse = mean_squared_error(y_true, y_pred)\n","    r2 = r2_score(y_true, y_pred)\n","    return {'model': label, 'MAE': mae, 'RMSE': rmse, 'R2': r2}\n","\n","baseline_results = [\n","    eval_metrics(y_test, np.full_like(y_test, baseline_global), 'Global median'),\n","    eval_metrics(y_test, pred_cat, 'Category median'),\n","    eval_metrics(y_test, pred_cat_size, 'Category+Size median'),\n","]\n","\n","pd.DataFrame(baseline_results)"],"id":"O64mj7QB5Sxe"},{"cell_type":"code","execution_count":null,"metadata":{"id":"fjL4Tq1Y5Sxg"},"outputs":[],"source":["preprocess = ColumnTransformer(\n","    transformers=[\n","        ('cat', OneHotEncoder(handle_unknown='ignore', sparse_output=False), categorical_cols),\n","        ('num', 'passthrough', numeric_cols)\n","    ]\n",")"],"id":"fjL4Tq1Y5Sxg"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":144},"id":"yTLdk8jj5Sxh","executionInfo":{"status":"ok","timestamp":1773416337839,"user_tz":-60,"elapsed":3436418,"user":{"displayName":"Bayan Dali","userId":"00422725621589951195"}},"outputId":"cd465f10-d5ea-4e25-9c69-1fc41f46d8e2"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["          model         MAE          RMSE        R2\n","2       XGBoost   93.406291  15084.836818  0.801032\n","0  RandomForest  130.324651  31974.103145  0.578263\n","1      AdaBoost  176.288547  47657.936920  0.371394"],"text/html":["\n","  <div id=\"df-e0869ca4-eaf8-404f-9215-d4066671382d\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>model</th>\n","      <th>MAE</th>\n","      <th>RMSE</th>\n","      <th>R2</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>2</th>\n","      <td>XGBoos