ies\": {\n        \"dtype\": \"number\",\n        \"std\": 41.523313734352804,\n        \"min\": 93.40629099207155,\n        \"max\": 176.2885473624943,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          93.40629099207155,\n          130.32465070486336,\n          176.2885473624943\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"RMSE\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 16290.2670797497,\n        \"min\": 15084.836818352962,\n        \"max\": 47657.93692012404,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          15084.836818352962,\n          31974.103144720662,\n          47657.93692012404\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"R2\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.21486779659804178,\n        \"min\": 0.3713942290630107,\n        \"max\": 0.8010317674146864,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          0.8010317674146864,\n          0.5782632011328444,\n          0.3713942290630107\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":8}],"source":["models = [\n","    ('RandomForest', RandomForestRegressor(\n","        n_estimators=300,\n","        max_depth=12,\n","        min_samples_leaf=3,\n","        random_state=42,\n","        n_jobs=-1\n","    )),\n","    ('AdaBoost', AdaBoostRegressor(\n","        n_estimators=300,\n","        learning_rate=0.05,\n","        random_state=42\n","    )),\n","]\n","\n","if xgboost_available:\n","    models.append(\n","        ('XGBoost', XGBRegressor(\n","            n_estimators=500,\n","            max_depth=6,\n","            learning_rate=0.05,\n","            subsample=0.8,\n","            colsample_bytree=0.8,\n","            objective='reg:squarederror',\n","            random_state=42,\n","            n_jobs=-1,\n","            verbosity=0\n","        ))\n","    )\n","\n","results = []\n","trained = {}\n","\n","for name, model in models:\n","    pipe = Pipeline([\n","        ('prep', preprocess),\n","        ('model', model)\n","    ])\n","\n","    pipe.fit(X_train, y_train)\n","    pred = pipe.predict(X_test)\n","\n","    res = eval_metrics(y_test, pred, name)\n","    results.append(res)\n","    trained[name] = {'pipe': pipe, 'pred': pred}\n","\n","pd.DataFrame(results).sort_values('RMSE')"],"id":"yTLdk8jj5Sxh"},{"cell_type":"code","execution_count":null,"metadata":{"id":"QzkowN9Y5Sxi","colab":{"base_uri":"https://localhost:8080/","height":562},"executionInfo":{"status":"ok","timestamp":1773416347627,"user_tz":-60,"elapsed":787,"user":{"displayName":"Bayan Dali","userId":"00422725621589951195"}},"outputId":"81662df8-71b5-4a5b-c226-9c45bd90c4a9"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# Pick best by RMSE\n","best_name = pd.DataFrame(results).sort_values('RMSE').iloc[0]['model']\n","\n","best_pred = trained[best_name]['pred']\n","\n","plt.figure(figsize=(6, 6))\n","plt.scatter(y_test, best_pred, alpha=0.3, s=10)\n","plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--')\n","plt.title(f'Predicted vs Actual Amount ({best_name})')\n","plt.xlabel('Actual Amount')\n","plt.ylabel('Predicted Amount')\n","plt.grid(alpha=0.3)\n","plt.show()"],"id":"QzkowN9Y5Sxi"}],"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":""},"colab":{"provenance":[]}},"nbformat":4,"nbformat_minor":5}